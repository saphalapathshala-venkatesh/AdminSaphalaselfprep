// LIVE CLASSES MODULE
model LiveClass {
  id              String          @id @default(cuid())
  tenantId        String          @default("default")
  title           String
  description     String?
  facultyId       String?
  faculty         Faculty?        @relation(fields: [facultyId], references: [id], onDelete: SetNull)
  courseId        String?
  course          Course?         @relation(fields: [courseId], references: [id], onDelete: SetNull)
  categoryId      String?
  examId          String?
  exam            Exam?           @relation(fields: [examId], references: [id], onDelete: SetNull)
  subjectId       String?
  topicId         String?
  subtopicId      String?
  sessionDate     DateTime?
  startTime       String?
  endTime         String?
  accessType      VideoAccessType @default(FREE)
  status          LiveClassStatus @default(DRAFT)
  platform        LivePlatform    @default(ZOOM)
  joinUrl         String?
  sessionCode     String?
  thumbnailUrl    String?
  notifyLearners  Boolean         @default(false)
  recordingPolicy RecordingPolicy @default(NO_RECORD)
  replayVideoId   String?
  publishedAt     DateTime?
  // unlockAt: students cannot access this live class before this datetime (null = no unlock restriction)
  unlockAt        DateTime?
