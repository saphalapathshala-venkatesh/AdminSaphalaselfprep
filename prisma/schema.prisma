  @@unique([couponId, productCategory])
  @@index([couponId])
}

// Junction: which exam categories (taxonomy Category) a coupon applies to
// Only used when appliesToAllExamCategories = false
model CouponExamCategoryScope {
  id         String   @id @default(cuid())
  couponId   String
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation("CouponExamCategoryScope", fields: [categoryId], references: [id], onDelete: Cascade)
  @@unique([couponId, categoryId])
  @@index([couponId])
}
// XP RULE ENGINE + LEDGER
