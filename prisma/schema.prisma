}

model UserXpSourceProgress {
  id               String       @id @default(cuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceType       XpSourceType
  sourceId         String
  completionCount  Int          @default(0)
  totalXpAwarded   Int          @default(0)
  updatedAt        DateTime     @updatedAt
  @@unique([userId, sourceType, sourceId])
  @@index([userId])
}

model UserAchievement {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementType String
  badgeCode       String
  badgeName       String
  levelNumber     Int?
  xpThreshold     Int?
  title           String
  message         String
  unlockedAt      DateTime @default(now())
  @@index([userId])
  @@unique([userId, badgeCode])
}

// REVENUE + ANALYTICS (minimal storage; charts computed)
model Purchase {
  id             String @id @default(cuid())
  userId         String
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  packageId      String?
  package        ProductPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)
  couponId       String?
  coupon         Coupon? @relation(fields: [couponId], references: [id], onDelete: SetNull)
  paymentOrderId String? @unique   // DB-level guard: exactly one Purchase per PaymentOrder
  stream         RevenueStream
  currency       String @default("INR")
  grossPaise     Int
  feePaise       Int    @default(0)
  netPaise       Int
  legalAcceptedAt   DateTime?
  legalVersion      String?
  createdAt      DateTime @default(now())
  refund         Refund?
  @@index([stream, createdAt])
  @@index([userId, createdAt])
}

enum RefundStatus {
  PENDING
  APPROVED
  PARTIALLY_APPROVED
  REJECTED
  REFUNDED
}

// ── Student-initiated refund workflow ──────────────────────────────────────────
enum RefundRequestStatus {
  REQUESTED     // Student submitted; awaiting admin triage
  UNDER_REVIEW  // Admin has opened the case
  APPROVED      // Admin approved; ready to process
  REJECTED      // Admin denied
  PROCESSED     // Refund money returned (gateway execution in future phase)
  FAILED        // Attempted processing failed
  CANCELLED     // Student or admin cancelled before a decision
}

enum RefundReasonCategory {
  CHANGED_MIND
  TECHNICAL_ISSUE
  CONTENT_NOT_AS_DESCRIBED
  DUPLICATE_PURCHASE
  COURSE_NOT_STARTED
  OTHER
}

model Refund {
  id              String       @id @default(cuid())
  purchaseId      String       @unique
  purchase        Purchase     @relation(fields: [purchaseId], references: [id])
  userId          String
  user            User         @relation("RefundUser", fields: [userId], references: [id], onDelete: Cascade)
  amountPaidPaise Int
  requestedAt     DateTime     @default(now())
  reason          String
  consumptionPct  Float?
  adminRemarks    String?
  approvedPaise   Int?
  refundPct       Float?
  status          RefundStatus @default(PENDING)
  processedById   String?
  processedBy     User?        @relation("RefundAdmin", fields: [processedById], references: [id], onDelete: SetNull)
  processedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  @@index([status, createdAt])
  @@index([userId, createdAt])
}
model RefundRequest {
  id             String              @id @default(cuid())

  // Order linkage (source of truth for what was paid)
  paymentOrderId String
  paymentOrder   PaymentOrder        @relation(fields: [paymentOrderId], references: [id], onDelete: Restrict)

  // User linkage
  userId         String
  user           User                @relation("RefundRequestUser", fields: [userId], references: [id], onDelete: Cascade)

  // Package snapshot at request time (denormalised so it survives package edits)
  packageId      String?
  packageName    String?
  packageCode    String?

  // Financial
  paidPaise      Int                  // amount student paid (from PaymentOrder.finalAmountPaise)
  requestedPaise Int?                 // what student expects back (optional)
  approvedPaise  Int?                 // admin decision

  // Student reason
  reasonCategory RefundReasonCategory
  reasonText     String               // free-text from student

  // Admin workflow
  status         RefundRequestStatus @default(REQUESTED)
  adminNote      String?              // internal admin note

  reviewedById   String?
  reviewedBy     User?               @relation("RefundRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt     DateTime?

  processedById  String?
  processedBy    User?               @relation("RefundRequestProcessor", fields: [processedById], references: [id], onDelete: SetNull)
  processedAt    DateTime?

  // Gateway reference — populated when actual gateway refund is triggered (future)
  gatewayRefundRef String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([paymentOrderId])
}

// AUDIT LOGGING (LOCKED requirement)
model AuditLog {
  id          String   @id @default(cuid())
  actorId     String?
  actor       User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action      String
  entityType  String
  entityId    String?
  before      Json?
  after       Json?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())
  @@index([actorId, createdAt])
  @@index([entityType, entityId])
}

// VIDEO MODULE
enum CourseType {
  STANDARD
  PACKAGE
}

// Controls where a course appears in the student app (e.g. "Self Prep" section vs "Free Demo" section)
enum ProductCategory {
  FREE_DEMO
  COMPLETE_PREP_PACK
  VIDEO_ONLY
  SELF_PREP
  PDF_ONLY
  TEST_SERIES
  FLASHCARDS_ONLY
  CURRENT_AFFAIRS
}

model Course {
  id             String     @id @default(cuid())
  tenantId       String     @default("default")
  name           String
  description    String?
  categoryId     String?
  examId         String?
  exam           Exam?      @relation(fields: [examId], references: [id], onDelete: SetNull)
  courseType     CourseType @default(STANDARD)
  productCategory ProductCategory?
  isActive       Boolean    @default(true)
  hasHtmlCourse     Boolean    @default(false)
  hasVideoCourse    Boolean    @default(false)
  hasPdfCourse      Boolean    @default(false)
  hasTestSeries     Boolean    @default(false)
  hasFlashcardDecks       Boolean    @default(false)
  thumbnailUrl            String?
  featured                Boolean    @default(false)
  xpRedemptionEnabled     Boolean    @default(false)
  xpRedemptionMaxPercent  Int        @default(1)
  validityType            String?
  validityDays            Int?
  validityMonths          Int?
  validUntil              DateTime?
  createdAt               DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  videos         Video[]
  liveClasses    LiveClass[]
  @@index([categoryId])
  @@index([examId])
  @@index([tenantId])
  @@index([courseType])
  @@index([productCategory])
  @@index([featured])
}

model Faculty {
  id        String    @id @default(cuid())
  tenantId  String    @default("default")
  name      String
  title     String?
  bio       String?
  avatarUrl String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  videos    Video[]
  liveClasses LiveClass[]
  @@index([tenantId])
}

model Video {
  id               String          @id @default(cuid())
  tenantId         String          @default("default")
  title            String
  description      String?
  facultyId        String?
  faculty          Faculty?        @relation(fields: [facultyId], references: [id], onDelete: SetNull)
  courseId         String?
  course           Course?         @relation(fields: [courseId], references: [id], onDelete: SetNull)
  categoryId       String?
  examId           String?
  exam             Exam?           @relation(fields: [examId], references: [id], onDelete: SetNull)
  subjectId        String?
  topicId          String?
  subtopicId       String?
  accessType       VideoAccessType @default(FREE)
  status           VideoStatus     @default(DRAFT)
  lessonOrder      Int?            @default(0)
  durationSeconds  Int?
  thumbnailUrl     String?
  provider         VideoProvider   @default(MANUAL)
  providerVideoId  String?
  hlsUrl           String?
  playbackUrl      String?
  processingStatus String?
  processingError  String?
  allowPreview     Boolean         @default(false)
  tags             String[]        @default([])
  publishedAt      DateTime?
  // unlockAt: students cannot access this video before this datetime (null = no unlock restriction)
  unlockAt         DateTime?
  createdById      String
  createdBy        User            @relation("VideoCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  @@index([status])
  @@index([courseId])
  @@index([categoryId])
  @@index([examId])
  @@index([tenantId])
