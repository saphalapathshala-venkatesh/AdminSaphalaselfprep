// =============================================================================
// SCHEMA FREEZE NOTICE — DO NOT MODIFY DESTRUCTIVELY
// -----------------------------------------------------------------------------
// Audit date : 2026-03-16
// Auditor    : Production Stability Audit (pre-launch)
// Status     : LAUNCH-FROZEN until Saphala Self Prep goes live.
//
// This schema is shared by TWO production apps on ONE Neon PostgreSQL database:
//   1. Saphala Self Prep Admin Console (this repo)
//   2. Saphala Self Prep Student Frontend (separate repo)
//
// RULES (enforced until post-launch):
//   ✗ Never use --accept-data-loss with db push
//   ✗ Never drop columns or tables
//   ✗ Never rename columns
//   ✗ Never change column types
//   ✓ Additive changes only (new nullable columns with defaults are OK)
//   ✓ Always use ALTER TABLE ... ADD COLUMN IF NOT EXISTS for hotfixes
//
// AUDIT RESULT (2026-03-16):
//   All columns in User, Session, Attempt, AttemptAnswer, Question,
//   QuestionOption, Test, TestSeries, UserEntitlement, TestQuestion, and
//   TestSection are 100% aligned between Prisma schema and live DB.
//   Zero columns missing. Zero columns to restore.
// =============================================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
// ENUMS (locked behavior)
enum UserRole {
  SUPER_ADMIN
  ADMIN
  STUDENT
}
enum SessionType {
  ADMIN
  STUDENT
}
enum EntitlementStatus {
  ACTIVE
  EXPIRED
  REVOKED
}
enum DifficultyLevel {
  FOUNDATIONAL  // 1★
  PROFICIENT    // 2★
  MASTERY       // 3★
}
enum QuestionStatus {
  DRAFT
  APPROVED
}
enum QuestionType {
  MCQ_SINGLE
  MCQ_MULTIPLE
  // Practice only
  DRAG_REORDER
  DRAG_DROP
  FILL_BLANKS
  TRUE_FALSE
}
enum ImportStatus {
  PREVIEWED
  VALIDATED
  PARTIAL_IMPORTED
  IMPORTED
  FAILED
}
enum TestMode {
  TIMED
  SECTIONAL
  MULTI_SECTION
}
enum RevenueStream {
  TESTHUB
  SELFPREP_HTML
  FLASHCARDS
  PDF_ACCESS
  SMART_PRACTICE
  AI_ADDON
}
enum CouponDiscountType {
  PERCENT
  FLAT
}
enum FlashcardCardType {
  TITLE
  INFO
  QUIZ
  COMPARISON
  FILL_IN_BLANK
  MATCHING
  REORDER
  CATEGORIZATION
}

enum XpRuleKey {
  LOGIN_XP
  TEST_XP
  IMPROVEMENT_BONUS_XP
  FLASHCARD_XP
  RR_XP
  VIDEO_SHORT_XP
  VIDEO_LONG_XP
  HTML_XP
  STREAK_7_BONUS
  STREAK_30_BONUS
  STREAK_50_BONUS
  STREAK_100_BONUS
  REDEMPTION_UNLOCK_THRESHOLD
  REDEMPTION_CONVERSION_RATE
}

enum XpSourceType {
  VIDEO
  TEST
  FLASHCARD
  HTML
  DAILY_LOGIN
  STREAK_BONUS
  REDEMPTION
  ADMIN_ADJUSTMENT
}
// CONTENT FLOW ENUM
enum FlowContentType {
  VIDEO
  PDF
  FLASHCARD
}
// VIDEO MODULE ENUMS
enum VideoStatus {
  DRAFT
  UPLOADING
  PROCESSING
  READY
  PUBLISHED
  ARCHIVED
  FAILED
}
enum VideoAccessType {
  FREE
  PAID
}
enum VideoProvider {
  BUNNY
  YOUTUBE
  MANUAL
  OTHER
}
// LIVE CLASS MODULE ENUMS
enum LiveClassStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  COMPLETED
  CANCELLED
}
enum LivePlatform {
  ZOOM
  YOUTUBE_LIVE
  OTHER
}
enum RecordingPolicy {
  RECORD
  NO_RECORD
  RECORD_AND_SHARE
}
// CORE IDENTITY + SESSIONS (LOCKED)
model User {
  id           String    @id @default(cuid())
  email        String?   @unique
  mobile       String?   @unique
  name         String?
  passwordHash String
  role         UserRole  @default(STUDENT)
  isActive       Boolean   @default(true)
  isBlocked      Boolean   @default(false)
  blockedReason  String?
  maxWebDevices    Int       @default(1)
  allowMultiDevice Boolean   @default(false)
  fullName         String?
  deletedAt        DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  sessions       Session[]
  entitlements   UserEntitlement[]
  attempts       Attempt[]
  xpEvents       XpEvent[]
  xpLedger       XpLedgerEntry[]
  auditLogs      AuditLog[]    @relation("AuditActor")
  importJobs     ImportJob[]
  testSeries     TestSeries[]
  tests          Test[]
  flashcardDecks FlashcardDeck[]
  contentPages   ContentPage[]
  pdfAssets      PdfAsset[]
  coupons        Coupon[]
  xpRules        XpRule[]
  xpWallet       UserXpWallet?
  xpSourceProgress UserXpSourceProgress[]
  achievements   UserAchievement[]
  purchases      Purchase[]
  videos         Video[]       @relation("VideoCreatedBy")
  liveClasses    LiveClass[]   @relation("LiveClassCreatedBy")
  devices          UserDevice[]
  activities       UserActivity[]
  contentConsents  ContentConsent[]
  itemCompletions  UserItemCompletion[]
  infringementEvents InfringementEvent[]
  annotations        LearnerAnnotation[]
  infringementWarnings Int @default(0)
  infringementBlocked  Boolean @default(false)
  mustChangePassword   Boolean @default(false)
  legalAcceptedAt      DateTime?
  legalVersion         String?
  // Extended profile fields — nullable, optional
  state                String?
  gender               String?
  refunds              Refund[] @relation("RefundUser")
  processedRefunds     Refund[] @relation("RefundAdmin")
  refundRequests          RefundRequest[] @relation("RefundRequestUser")
  reviewedRefundRequests  RefundRequest[] @relation("RefundRequestReviewer")
  processedRefundRequests RefundRequest[] @relation("RefundRequestProcessor")
  paymentOrders        PaymentOrder[]  @relation("PaymentOrderUser")
  paymentConfigs       PaymentConfig[] @relation("PaymentConfigCreatedBy")
  @@index([role])
  @@index([isBlocked])
  @@index([deletedAt])
}
// FROZEN — shared with student frontend; do not add/drop/rename columns
model Session {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       SessionType @default(ADMIN)
  token      String      @unique
  expiresAt  DateTime
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())
  revokedAt  DateTime?
  @@index([userId, type])
  @@index([expiresAt])
}
// ENTITLEMENTS — FROZEN; shared with student frontend; do not add/drop/rename columns
model UserEntitlement {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  productCode  String
  status       EntitlementStatus @default(ACTIVE)
  validUntil   DateTime?
  purchaseId   String?
  tenantId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@unique([userId, productCode, tenantId])
  @@index([productCode, status])
}
// TAXONOMY (Category → Subject → Topic → Subtopic)
model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  subjects  Subject[]
  exams     Exam[]
  packages             ProductPackage[]      @relation("PackageExamCategory")
  couponExamScopes     CouponExamCategoryScope[] @relation("CouponExamCategoryScope")
}

// EXAM MASTER
// A product-level targeting layer under Category.
// Used for learner discovery, admin filtering, and product/content targeting.
// NOT part of the academic taxonomy (Category → Subject → Topic → Subtopic).
// NOT used in Question Bank or question tagging.
model Exam {
  id         String   @id @default(cuid())
  name       String
  slug       String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  courses        Course[]
  testSeries     TestSeries[]
  tests          Test[]
  contentPages   ContentPage[]
  pdfAssets      PdfAsset[]
  flashcardDecks FlashcardDeck[]
  videos         Video[]
  liveClasses    LiveClass[]
  @@unique([categoryId, slug])
  @@index([categoryId])
}
model Subject {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  topics     Topic[]
  @@unique([categoryId, name])
  @@index([categoryId])
}
model Topic {
  id        String   @id @default(cuid())
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  subtopics Subtopic[]
  @@unique([subjectId, name])
  @@index([subjectId])
}
model Subtopic {
  id      String @id @default(cuid())
  topicId String
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Restrict)
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  questions Question[]
  flashcardCards FlashcardCard[]
  contentPages ContentPage[]
  @@unique([topicId, name])
  @@index([topicId])
}
// QUESTION BANK
// - exact duplicates blocked (via contentHash unique)
// - near duplicates warned (handled in app layer via similarity checks)
model Question {
  id           String         @id @default(cuid())
  categoryId   String?
  subjectId    String?
  topicId      String?
  subtopicId   String?
  subtopic     Subtopic?      @relation(fields: [subtopicId], references: [id], onDelete: SetNull)
  type         QuestionType
  difficulty   DifficultyLevel
  status       QuestionStatus @default(DRAFT)
  stem              String
  stemSecondary     String?
  explanation       String?
  explanationSecondary String?
  tags         String[]       @default([])
  contentHash  String         @unique
  options      QuestionOption[]
  testQuestions TestQuestion[]
  attemptAnswers AttemptAnswer[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@index([type, status])
  @@index([difficulty])
  @@index([subtopicId])
}
model QuestionOption {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text          String
  textSecondary String?
  isCorrect  Boolean  @default(false)
  order      Int
  @@index([questionId])
}
// IMPORT SYSTEM (CSV & DOCX)
model ImportJob {
  id            String       @id @default(cuid())
  createdById   String
  createdBy     User         @relation(fields: [createdById], references: [id], onDelete: Restrict)
  fileName      String
  fileType      String
  storageUrl    String?
  status        ImportStatus @default(PREVIEWED)
  totalRows     Int          @default(0)
  validRows     Int          @default(0)
  invalidRows   Int          @default(0)
  reportUrl     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  rows          ImportRow[]
  @@index([createdById, status])
}
model ImportRow {
  id          String    @id @default(cuid())
  importJobId String
  importJob   ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  rowNumber   Int
  rawData     Json
  editedData  Json?
  isValid     Boolean   @default(false)
  errorField  String?
  errorMsg    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([importJobId, rowNumber])
  @@index([importJobId, isValid])
}
// TEST SERIES + TESTS + SECTIONS
model TestSeries {
  id           String   @id @default(cuid())
  title        String
  description  String?
  categoryId   String?
  examId       String?
  exam         Exam?    @relation(fields: [examId], references: [id], onDelete: SetNull)
  subjectIds   String[] @default([])
  pricePaise    Int      @default(0)
  discountPaise Int      @default(0)
  currency      String   @default("INR")
  thumbnailUrl  String?
  scheduleJson Json?
  isFree       Boolean  @default(false)
  isPublished  Boolean  @default(false)
  createdById  String
  createdBy    User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tests        Test[]
  @@index([examId])
  @@index([isPublished])
}
model Test {
  id             String   @id @default(cuid())
  seriesId        String?
  series          TestSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  categoryId     String?
  examId         String?
  exam           Exam?       @relation(fields: [examId], references: [id], onDelete: SetNull)
  title          String
  instructions   String?
  mode           TestMode
  isTimed              Boolean  @default(true)
  durationSec          Int?
  allowPause           Boolean  @default(false)
  strictSectionMode    Boolean  @default(false)
  shuffleQuestions     Boolean  @default(false)
  shuffleOptions       Boolean  @default(false)
  shuffleGroups        Boolean  @default(false)
  shuffleGroupChildren Boolean  @default(false)
  xpEnabled            Boolean  @default(false)
  xpValue              Int      @default(0)
  testStartTime        DateTime?
  totalQuestions       Int?
  // Default marking scheme for the whole test (applied as hint in builder; per-question overrides via TestQuestion.marks)
  marksPerQuestion     Float?
  negativeMarksPerQuestion Float?
  isFree               Boolean  @default(false)
  isPublished          Boolean  @default(false)
  publishedAt          DateTime?
  // unlockAt: students cannot access this test before this datetime (null = no unlock restriction)
  unlockAt             DateTime?
  // isQuiz: when true, this record belongs to the Quiz feature (standalone, no series required).
  // Existing tests always have isQuiz=false. Quiz admin at /admin/quiz filters isQuiz=true.
  isQuiz               Boolean  @default(false)
  // Student-frontend columns — DO NOT DROP
  code                 String?  @unique
  attemptsAllowed      Int      @default(2)
  languageAvailable    LanguageAvailable @default(BOTH)
  subjectIds           String[] @default([])
  syllabusTags         String[] @default([])
  createdById    String
  createdBy      User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  sections       TestSection[]
  questions      TestQuestion[]
  attempts       Attempt[]
  @@index([isPublished])
  @@index([seriesId])
  @@index([examId])
}
model TestSection {
  id              String        @id @default(cuid())
  testId          String
  test            Test          @relation(fields: [testId], references: [id], onDelete: Cascade)
  parentSectionId String?
  parentSection   TestSection?  @relation("SubsectionParent", fields: [parentSectionId], references: [id], onDelete: Cascade)
  subsections     TestSection[] @relation("SubsectionParent")
  title           String
  order           Int
  durationSec     Int?
  targetCount     Int?
  questions       TestQuestion[]
  @@index([testId, order])
  @@index([parentSectionId])
}
model TestQuestion {
  id            String       @id @default(cuid())
  testId        String
  sectionId     String?
  test          Test         @relation(fields: [testId], references: [id], onDelete: Cascade)
  section       TestSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  questionId    String
  question      Question     @relation(fields: [questionId], references: [id], onDelete: Restrict)
  order         Int
  marks         Float        @default(1)
  negativeMarks Float        @default(0)
  @@unique([testId, questionId])
  @@index([testId, order])
  @@index([sectionId, order])
}
// ATTEMPTS + RAPID REINFORCEMENT
// FROZEN — shared with student frontend; do not add/drop/rename columns
model Attempt {
  id              String             @id @default(cuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  testId          String
  test            Test               @relation(fields: [testId], references: [id], onDelete: Cascade)
  startedAt       DateTime           @default(now())
  submittedAt     DateTime?
  scorePct        Float              @default(0)
  correctCount    Int                @default(0)
  wrongCount      Int                @default(0)
  unansweredCount Int                @default(0)
  rrGenerated     Boolean            @default(false)
  // Student-frontend columns — DO NOT DROP
  attemptNumber      Int                @default(1)
  language           LanguageAvailable  @default(EN)
  status             AttemptStatus      @default(IN_PROGRESS)
  totalTimeUsedMs    Int                @default(0)
  endsAt             DateTime?
  lockedSessionToken String?
  answers            AttemptAnswer[]
  pauseEvents        AttemptPause[]
  sectionSubmits     AttemptSectionSubmit[]
  createdAt       DateTime           @default(now())
  @@index([userId, startedAt])
  @@index([testId, startedAt])
}
// FROZEN — shared with student frontend; do not add/drop/rename columns
model AttemptAnswer {
  id                String   @id @default(cuid())
  attemptId         String
  attempt           Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId        String
  question          Question @relation(fields: [questionId], references: [id], onDelete: Restrict)
  selectedOptionIds String[] @default([])
  isCorrect         Boolean  @default(false)
  // Student-frontend columns — DO NOT DROP
  isMarkedForReview Boolean  @default(false)
  timeSpentMs       Int      @default(0)
  // Legacy singular field — kept for backward compat with older student app versions
  selectedOptionId  String?
  savedAt           DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
}
// Pause events for an Attempt — created on pause, updated on resume
model AttemptPause {
  id        String    @id @default(cuid())
  attemptId String
  attempt   Attempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  pausedAt  DateTime  @default(now())
  resumedAt DateTime?
  @@index([attemptId])
}

// Tracks per-section submissions in strict-section-mode tests
// One row per (attempt, section) — unique enforced; idempotent on duplicate submit
model AttemptSectionSubmit {
  id          String   @id @default(cuid())
  attemptId   String
  attempt     Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  sectionId   String
  submittedAt DateTime @default(now())
  @@unique([attemptId, sectionId])
  @@index([attemptId])
}

// FLASHCARDS (Deck → Cards)
model FlashcardDeck {
  id             String  @id @default(cuid())
  title          String
  subtitle       String?
  description    String?
  categoryId     String?
  examId         String?
  exam           Exam?   @relation(fields: [examId], references: [id], onDelete: SetNull)
  subjectId      String?
  topicId        String?
  subtopicId     String?
  titleTemplate  String  @default("minimal_academic")
  titleImageUrl  String?
  subjectColor   String?
  xpEnabled      Boolean  @default(false)
  xpValue        Int      @default(0)
  isPublished    Boolean  @default(false)
  // unlockAt: students cannot access this deck before this datetime (null = no unlock restriction)
  unlockAt       DateTime?
  createdById    String
  createdBy      User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  cards          FlashcardCard[]
  @@index([examId])
  @@index([categoryId])
}
model FlashcardCard {
  id          String            @id @default(cuid())
  deckId      String
  deck        FlashcardDeck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  subtopicId  String?
  subtopic    Subtopic?         @relation(fields: [subtopicId], references: [id], onDelete: SetNull)
  cardType    FlashcardCardType @default(INFO)
  front       String            @default("")
  back        String            @default("")
  content     Json?
  imageUrl    String?
  order       Int
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  @@index([deckId, order])
}
model ContentConsent {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentType  String
  contentId    String
  accepted     Boolean
  termsVersion String   @default("content_protection_terms_v1")
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  @@index([userId, contentType, contentId])
  @@index([createdAt])
}
// CONTENT LIBRARY
// Layer 1: HTML learning pages (non-downloadable, light XP)
// Layer 2: PDF library (downloadable, requires entitlement, no XP)
model ContentPage {
  id          String @id @default(cuid())
  title       String
  categoryId  String?
  examId      String?
  exam        Exam?   @relation(fields: [examId], references: [id], onDelete: SetNull)
  subjectId   String?
  topicId     String?
  subtopicId  String?
  subtopic    Subtopic? @relation(fields: [subtopicId], references: [id], onDelete: SetNull)
  body        String
  xpEnabled   Boolean @default(false)
  xpValue     Int     @default(0)
  isPublished Boolean @default(false)
  publishedAt DateTime?
  // unlockAt: students cannot access this e-book before this datetime (null = no unlock restriction)
  unlockAt    DateTime?
  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ebookPages  EBookPage[]
  @@index([isPublished])
  @@index([subtopicId])
  @@index([categoryId])
  @@index([examId])
}

model EBookPage {
  id             String      @id @default(cuid())
  ebookId        String
  ebook          ContentPage @relation(fields: [ebookId], references: [id], onDelete: Cascade)
  title          String?
  contentHtml    String
  // contentBlocks: structured block JSON (v1 BlockDoc). When present, takes precedence over contentHtml.
  // Null = legacy page (render contentHtml). Non-null = block-based page (render via BlockRenderer).
  contentBlocks  Json?
  orderIndex     Int
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  @@index([ebookId, orderIndex])
}
model PdfAsset {
  id             String @id @default(cuid())
  title          String
  fileUrl        String
  fileData       Bytes?
  fileSize       Int?
  mimeType       String? @default("application/pdf")
  categoryId     String?
  examId         String?
  exam           Exam?   @relation(fields: [examId], references: [id], onDelete: SetNull)
  subjectId      String?
  topicId        String?
  subtopicId     String?
  isDownloadable Boolean @default(true)
  isPublished    Boolean @default(false)
  publishedAt    DateTime?
  // unlockAt: students cannot access this PDF before this datetime (null = no unlock restriction)
  unlockAt       DateTime?
  createdById    String
  createdBy      User   @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@index([isPublished])
  @@index([categoryId])
  @@index([examId])
}
// PRODUCT BUILDER (packages → entitlements)
model ProductPackage {
  id                String  @id @default(cuid())
  code              String  @unique
  name              String
  description       String?
  entitlementCodes  String[] @default([])
  pricePaise        Int      @default(0)
  currency          String   @default("INR")
  isActive          Boolean  @default(true)
  // Commercial targeting: which ProductCategory enum value this package belongs to
  productCategory   ProductCategory?
  // Exam targeting: which exam/category group this package targets (links to Category taxonomy)
  categoryId        String?
  examCategory      Category? @relation("PackageExamCategory", fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  purchases         Purchase[]
  paymentOrders     PaymentOrder[]
}
// COUPONS
model Coupon {
  id           String @id @default(cuid())
  code         String @unique
  discountType CouponDiscountType
  discountValue Int
  validFrom    DateTime?
  validUntil   DateTime?
  usageLimit   Int?
  perUserLimit Int?
  // Legacy entitlement-based applicability (kept for backward compatibility)
  applicableEntitlements String[] @default([])
  // Dual-layer applicability flags (default true = applies to all, backward compatible)
  appliesToAllPaidProductCategories Boolean @default(true)
  appliesToAllExamCategories        Boolean @default(true)
  isActive     Boolean @default(true)
  createdById  String
  createdBy    User   @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt    DateTime @default(now())
  updatedAt     DateTime @updatedAt
  purchases     Purchase[]
  paymentOrders PaymentOrder[]
  productCategoryScopes CouponProductCategoryScope[]
  examCategoryScopes    CouponExamCategoryScope[]
}

// Junction: which paid product categories a coupon applies to
// Only used when appliesToAllPaidProductCategories = false
// productCategory stores the ProductCategory enum value (e.g. "TEST_SERIES").
// FREE_DEMO is excluded at the API layer — never inserted here.
model CouponProductCategoryScope {
