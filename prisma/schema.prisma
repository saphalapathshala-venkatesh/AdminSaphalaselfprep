// COURSE CONTENT BUILDER
// Structured folder tree + content mappings for a specific course.
// Folders are neutral containers; items are mappings only (never delete source content).

enum CourseItemType {
  VIDEO
  LIVE_CLASS
  PDF
  FLASHCARD_DECK
  HTML_PAGE
  QUIZ
  EXTERNAL_LINK
}

enum LessonStatus {
  DRAFT
  PUBLISHED
}

model CourseFolder {
  id          String   @id @default(cuid())
  tenantId    String   @default("default")
  courseId    String
  parentId    String?
  title       String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([courseId])
  @@index([parentId])
  @@index([courseId, parentId, sortOrder])
}

model CourseContentItem {
  id            String         @id @default(cuid())
  tenantId      String         @default("default")
  courseId      String
  folderId      String?
  itemType      CourseItemType
  sourceId      String
  titleSnapshot String?
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([courseId, itemType, sourceId])
  @@index([courseId])
  @@index([folderId])
  @@index([courseId, folderId, sortOrder])
}

// COURSE PACKAGE ITEMS
// Maps existing STANDARD courses into a PACKAGE course by reference.
// No content duplication — child course remains the source of truth.
model CoursePackageItem {
  id              String   @id @default(cuid())
  tenantId        String   @default("default")
  packageCourseId String
  childCourseId   String
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([packageCourseId, childCourseId])
  @@index([packageCourseId, sortOrder])
  @@index([childCourseId])
}

// CONTENT FLOW
// Unified ordered sequence of mixed content (Video, PDF, Flashcard) for a given context.
// Context is defined by any combination of courseId/categoryId/subjectId/topicId/subtopicId.
// Removing a flow item never deletes the underlying source content.
model ContentFlowItem {
  id            String          @id @default(cuid())
  tenantId      String          @default("default")
  courseId      String?
  categoryId    String?
  subjectId     String?
  topicId       String?
  subtopicId    String?
  contentType   FlowContentType
  contentId     String
  titleSnapshot String?
  displayOrder  Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  @@index([tenantId, courseId])
  @@index([tenantId, categoryId, subjectId, topicId, subtopicId])
}

// USER DEVICE TRACKING
enum DeviceType {
  DESKTOP
  MOBILE
  TABLET
  UNKNOWN
}

model UserDevice {
  id            String     @id @default(cuid())
  tenantId      String     @default("default")
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceKey     String
  deviceType    DeviceType @default(UNKNOWN)
  browser       String?
  os            String?
  userAgent     String?
  ipAddressLast String?
  label         String?
  firstSeenAt   DateTime   @default(now())
  lastSeenAt    DateTime   @default(now())
  isActive      Boolean    @default(true)
  isBlocked     Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  @@unique([userId, deviceKey])
  @@index([userId])
  @@index([deviceKey])
  @@index([isActive])
  @@index([lastSeenAt])
}

// USER ACTIVITY LOG
enum ActivityType {
  LOGIN_SUCCESS
  LOGIN_BLOCKED_DEVICE_LIMIT
  LOGIN_BLOCKED_USER
  LOGOUT
  DEVICE_REGISTERED
  DEVICE_REMOVED
  DEVICE_RESET
  GLOBAL_DEVICE_RESET
  USER_BLOCKED
  USER_UNBLOCKED
  USER_EDITED
  USER_SOFT_DELETED
  USER_RESTORED
  SESSION_REVOKED
  CONTENT_OPENED
  TERMS_ACCEPTED
  TERMS_DECLINED
  CONTENT_COMPLETED
  DECK_OPENED
  DECK_COMPLETED
  CARD_VIEWED
}

model UserActivity {
  id           String       @id @default(cuid())
  tenantId     String       @default("default")
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  activityType ActivityType
  meta         String?
  deviceKey    String?
  ipAddress    String?
  createdAt    DateTime     @default(now())
  @@index([userId])
  @@index([userId, activityType])
  @@index([createdAt])
}

// COURSE CURRICULUM STRUCTURE
// Subject Section → Chapter → Lesson → LessonItem
// Each level is semantically distinct and named for clarity.

model CourseSubjectSection {
  id          String   @id @default(cuid())
  tenantId    String   @default("default")
  courseId    String
  subjectId   String
  label       String?
  subtitle    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  chapters    Chapter[]

  @@unique([courseId, subjectId])
  @@index([courseId, sortOrder])
}

model Chapter {
  id          String               @id @default(cuid())
  tenantId    String               @default("default")
  sectionId   String
  section     CourseSubjectSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  title       String
  description String?
  sortOrder   Int                  @default(0)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  lessons     Lesson[]

  @@index([sectionId, sortOrder])
}

model Lesson {
  id          String       @id @default(cuid())
  tenantId    String       @default("default")
  chapterId   String
  chapter     Chapter      @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      LessonStatus @default(PUBLISHED)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  items       LessonItem[]

  @@index([chapterId, sortOrder])
}

model LessonItem {
  id            String         @id @default(cuid())
  tenantId      String         @default("default")
  lessonId      String
  lesson        Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  itemType      CourseItemType
  // sourceId is null for EXTERNAL_LINK items (no source content record in DB)
  sourceId      String?
  titleSnapshot String?
  sortOrder     Int            @default(0)
  // unlockAt: overrides the content-level unlockAt for this specific course item.
  // Effective logic: LessonItem.unlockAt ?? sourceContent.unlockAt ?? null
  // null = no LessonItem-level restriction (falls back to content-level or open immediately)
  unlockAt      DateTime?
  // EXTERNAL_LINK fields (only populated when itemType = EXTERNAL_LINK)
  externalUrl   String?
  description   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  completions   UserItemCompletion[]

  @@unique([lessonId, itemType, sourceId])
  @@index([lessonId, sortOrder])
}

model UserItemCompletion {
  id           String     @id @default(cuid())
  tenantId     String     @default("default")
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonItemId String
  lessonItem   LessonItem @relation(fields: [lessonItemId], references: [id], onDelete: Cascade)
  completedAt  DateTime   @default(now())

  @@unique([userId, lessonItemId])
  @@index([userId])
  @@index([lessonItemId])
}

// INFRINGEMENT MONITORING
// Tracks detectable copy/right-click/selection attempts on protected content.
// Warnings auto-increment on User; 3rd offense triggers infringementBlocked = true.
enum InfringementEventType {
  COPY_ATTEMPT
  RIGHT_CLICK_ATTEMPT
  SELECTION_ATTEMPT
  KEYBOARD_COPY_ATTEMPT
}

enum InfringementAction {
  LOGGED
  WARNING_1
  WARNING_2
  AUTO_BLOCKED
}

model InfringementEvent {
  id              String               @id @default(cuid())
  tenantId        String               @default("default")
  userId          String
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentType     String
  contentId       String
  courseId        String?
  lessonId        String?
  eventType       InfringementEventType
  userAgent       String?
  ipAddress       String?
  warningCountAt  Int                  @default(0)
  actionTaken     InfringementAction   @default(LOGGED)
  createdAt       DateTime             @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([contentType, contentId])
}

// LEARNER ANNOTATIONS
// User-specific highlights/underlines on E-Book and PDF content.
// rangeData stores serialized DOM range info for reapplication.
enum AnnotationType {
  HIGHLIGHT
  UNDERLINE
}

// Student-frontend enums — shared with the student app; DO NOT rename or remove values
enum AttemptStatus {
  IN_PROGRESS
  PAUSED
  SUBMITTED
  EXPIRED
}

enum LanguageAvailable {
  EN
  TE
  BOTH
}

// ============================================================
// PAYMENT INFRASTRUCTURE
// ============================================================

enum PaymentOrderStatus {
  CREATED    // PaymentOrder row created, awaiting Cashfree order creation
  PENDING    // Cashfree order created, payment in-progress
  PAID       // Confirmed by webhook
  FAILED     // Payment failed or expired
  CANCELLED  // Manually cancelled
}

// Stores active/inactive payment provider credentials.
// Only one config should have isActive=true at a time.
// Admin-switchable from the dashboard — never hardcoded.
model PaymentConfig {
  id            String   @id @default(cuid())
  provider      String   @default("CASHFREE")  // "CASHFREE" only for now
  displayName   String                          // e.g. "Main Cashfree (Prod)"
  environment   String   @default("TEST")       // "TEST" | "PROD"
  appId         String
  secretKey     String
  webhookSecret String
  isActive      Boolean  @default(false)
  notes         String?
  createdById   String
  createdBy     User     @relation("PaymentConfigCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orders        PaymentOrder[]
  @@index([isActive])
}

// Tracks the full lifecycle of a payment attempt.
// Created before Cashfree order; updated by webhook on completion.
model PaymentOrder {
  id                String             @id @default(cuid())
  userId            String
  user              User               @relation("PaymentOrderUser", fields: [userId], references: [id], onDelete: Restrict)
  packageId         String
  package           ProductPackage     @relation(fields: [packageId], references: [id], onDelete: Restrict)
  couponId          String?
  coupon            Coupon?            @relation(fields: [couponId], references: [id], onDelete: SetNull)
  paymentConfigId   String?
  paymentConfig     PaymentConfig?     @relation(fields: [paymentConfigId], references: [id], onDelete: SetNull)
  grossPaise        Int                // original package price
  discountPaise     Int    @default(0) // coupon discount applied
  finalAmountPaise  Int                // backend-calculated final charge
  currency          String @default("INR")
  status            PaymentOrderStatus @default(CREATED)
  provider          String @default("CASHFREE")
  providerOrderId   String?            // Cashfree cf_order_id
  providerPaymentId String? @unique    // Cashfree payment ID — unique per real payment
  paymentSessionId  String?            // Cashfree payment_session_id (for JS SDK)
  legalAcceptedAt   DateTime?
  legalVersion      String?
  purchaseId        String?            // linked Purchase.id after payment success
  metadata          Json?
  paidAt            DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  refundRequests    RefundRequest[]
  @@index([userId, createdAt])
  @@index([providerOrderId])
  @@index([status, createdAt])
}

model LearnerAnnotation {
  id           String         @id @default(cuid())
  tenantId     String         @default("default")
  userId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentType  String
  contentId    String
  annotationType AnnotationType @default(HIGHLIGHT)
  selectedText String
  rangeData    Json
  color        String         @default("#fef9c3")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([userId, contentType, contentId])
  @@index([userId])
}
