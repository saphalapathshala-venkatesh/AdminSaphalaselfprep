generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
// ENUMS (locked behavior)
enum UserRole {
  SUPER_ADMIN
  ADMIN
  STUDENT
}
enum SessionType {
  ADMIN
  STUDENT
}
enum EntitlementStatus {
  ACTIVE
  EXPIRED
  REVOKED
}
enum DifficultyLevel {
  FOUNDATIONAL  // 1★
  PROFICIENT    // 2★
  MASTERY       // 3★
}
enum QuestionStatus {
  DRAFT
  APPROVED
}
enum QuestionType {
  MCQ_SINGLE
  MCQ_MULTIPLE
  // Practice only
  DRAG_REORDER
  DRAG_DROP
  FILL_BLANKS
  TRUE_FALSE
}
enum ImportStatus {
  PREVIEWED
  VALIDATED
  PARTIAL_IMPORTED
  IMPORTED
  FAILED
}
enum TestMode {
  TIMED
  SECTIONAL
  MULTI_SECTION
}
enum RevenueStream {
  TESTHUB
  SELFPREP_HTML
  FLASHCARDS
  PDF_ACCESS
  SMART_PRACTICE
  AI_ADDON
}
enum CouponDiscountType {
  PERCENT
  FLAT
}
enum XpRuleKey {
  LOGIN_XP
  TEST_XP
  IMPROVEMENT_BONUS_XP
  FLASHCARD_XP
  RR_XP
}
// CONTENT FLOW ENUM
enum FlowContentType {
  VIDEO
  PDF
  FLASHCARD
}
// VIDEO MODULE ENUMS
enum VideoStatus {
  DRAFT
  UPLOADING
  PROCESSING
  READY
  PUBLISHED
  ARCHIVED
  FAILED
}
enum VideoAccessType {
  FREE
  PAID
}
enum VideoProvider {
  BUNNY
  YOUTUBE
  MANUAL
  OTHER
}
// LIVE CLASS MODULE ENUMS
enum LiveClassStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  COMPLETED
  CANCELLED
}
enum LivePlatform {
  ZOOM
  YOUTUBE_LIVE
  OTHER
}
enum RecordingPolicy {
  RECORD
  NO_RECORD
  RECORD_AND_SHARE
}
// CORE IDENTITY + SESSIONS (LOCKED)
model User {
  id           String    @id @default(cuid())
  email        String?   @unique
  mobile       String?   @unique
  name         String?
  passwordHash String
  role         UserRole  @default(STUDENT)
  isActive       Boolean   @default(true)
  isBlocked      Boolean   @default(false)
  blockedReason  String?
  maxWebDevices  Int       @default(1)
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  sessions       Session[]
  entitlements   UserEntitlement[]
  attempts       Attempt[]
  xpEvents       XpEvent[]
  xpLedger       XpLedgerEntry[]
  auditLogs      AuditLog[]    @relation("AuditActor")
  importJobs     ImportJob[]
  testSeries     TestSeries[]
  tests          Test[]
  flashcardDecks FlashcardDeck[]
  contentPages   ContentPage[]
  pdfAssets      PdfAsset[]
  coupons        Coupon[]
  xpRules        XpRule[]
  purchases      Purchase[]
  videos         Video[]       @relation("VideoCreatedBy")
  liveClasses    LiveClass[]   @relation("LiveClassCreatedBy")
  devices        UserDevice[]
  activities     UserActivity[]
  @@index([role])
  @@index([isBlocked])
  @@index([deletedAt])
}
model Session {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       SessionType @default(ADMIN)
  token      String      @unique
  expiresAt  DateTime
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())
  revokedAt  DateTime?
  @@index([userId, type])
  @@index([expiresAt])
}
// ENTITLEMENTS (LOCKED TABLE + FIELDS)
model UserEntitlement {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  productCode  String
  status       EntitlementStatus @default(ACTIVE)
  validUntil   DateTime?
  purchaseId   String?
  tenantId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@unique([userId, productCode, tenantId])
  @@index([productCode, status])
}
// TAXONOMY (Category → Subject → Topic → Subtopic)
model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  subjects  Subject[]
}
model Subject {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  topics     Topic[]
  @@unique([categoryId, name])
  @@index([categoryId])
}
model Topic {
  id        String   @id @default(cuid())
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  subtopics Subtopic[]
  @@unique([subjectId, name])
  @@index([subjectId])
}
model Subtopic {
  id      String @id @default(cuid())
  topicId String
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Restrict)
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  questions Question[]
  flashcardCards FlashcardCard[]
  contentPages ContentPage[]
  @@unique([topicId, name])
  @@index([topicId])
}
// QUESTION BANK
// - exact duplicates blocked (via contentHash unique)
// - near duplicates warned (handled in app layer via similarity checks)
model Question {
  id           String         @id @default(cuid())
  categoryId   String?
  subjectId    String?
  topicId      String?
  subtopicId   String?
  subtopic     Subtopic?      @relation(fields: [subtopicId], references: [id], onDelete: SetNull)
  type         QuestionType
  difficulty   DifficultyLevel
  status       QuestionStatus @default(DRAFT)
  stem         String
  explanation  String?
  tags         String[]       @default([])
  contentHash  String         @unique
  options      QuestionOption[]
  testQuestions TestQuestion[]
  attemptAnswers AttemptAnswer[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@index([type, status])
  @@index([difficulty])
  @@index([subtopicId])
}
model QuestionOption {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean  @default(false)
  order      Int
  @@index([questionId])
}
// IMPORT SYSTEM (CSV & DOCX)
model ImportJob {
  id            String       @id @default(cuid())
  createdById   String
  createdBy     User         @relation(fields: [createdById], references: [id], onDelete: Restrict)
  fileName      String
  fileType      String
  storageUrl    String?
  status        ImportStatus @default(PREVIEWED)
  totalRows     Int          @default(0)
  validRows     Int          @default(0)
  invalidRows   Int          @default(0)
  reportUrl     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  rows          ImportRow[]
  @@index([createdById, status])
}
model ImportRow {
  id          String    @id @default(cuid())
  importJobId String
  importJob   ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  rowNumber   Int
  rawData     Json
  editedData  Json?
  isValid     Boolean   @default(false)
  errorField  String?
  errorMsg    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([importJobId, rowNumber])
  @@index([importJobId, isValid])
}
// TEST SERIES + TESTS + SECTIONS
model TestSeries {
  id           String   @id @default(cuid())
  title        String
  description  String?
  categoryId   String?
  subjectIds   String[] @default([])
  pricePaise    Int      @default(0)
  discountPaise Int      @default(0)
  currency      String   @default("INR")
  thumbnailUrl  String?
  scheduleJson Json?
  isPublished  Boolean  @default(false)
  createdById  String
  createdBy    User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tests        Test[]
  @@index([isPublished])
}
model Test {
  id             String   @id @default(cuid())
  seriesId        String?
  series          TestSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  categoryId     String?
  title          String
  instructions   String?
  mode           TestMode
  isTimed              Boolean  @default(true)
  durationSec          Int?
  allowPause           Boolean  @default(false)
  strictSectionMode    Boolean  @default(false)
  shuffleQuestions     Boolean  @default(false)
  shuffleOptions       Boolean  @default(false)
  shuffleGroups        Boolean  @default(false)
  shuffleGroupChildren Boolean  @default(false)
  isPublished          Boolean  @default(false)
  publishedAt    DateTime?
  createdById    String
  createdBy      User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  sections       TestSection[]
  questions      TestQuestion[]
  attempts       Attempt[]
  @@index([isPublished])
  @@index([seriesId])
}
model TestSection {
  id              String        @id @default(cuid())
  testId          String
  test            Test          @relation(fields: [testId], references: [id], onDelete: Cascade)
  parentSectionId String?
  parentSection   TestSection?  @relation("SubsectionParent", fields: [parentSectionId], references: [id], onDelete: Cascade)
  subsections     TestSection[] @relation("SubsectionParent")
  title           String
  order           Int
  durationSec     Int?
  targetCount     Int?
  questions       TestQuestion[]
  @@index([testId, order])
  @@index([parentSectionId])
}
model TestQuestion {
  id            String       @id @default(cuid())
  testId        String
  sectionId     String?
  test          Test         @relation(fields: [testId], references: [id], onDelete: Cascade)
  section       TestSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  questionId    String
  question      Question     @relation(fields: [questionId], references: [id], onDelete: Restrict)
  order         Int
  marks         Float        @default(1)
  negativeMarks Float        @default(0)
  @@unique([testId, questionId])
  @@index([testId, order])
  @@index([sectionId, order])
}
// ATTEMPTS + RAPID REINFORCEMENT
model Attempt {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  testId      String
  test        Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  startedAt   DateTime @default(now())
  submittedAt DateTime?
  scorePct    Float    @default(0)
  correctCount Int     @default(0)
  wrongCount   Int     @default(0)
  unansweredCount Int  @default(0)
  rrGenerated Boolean  @default(false)
  answers     AttemptAnswer[]
  createdAt   DateTime @default(now())
  @@index([userId, startedAt])
  @@index([testId, startedAt])
}
model AttemptAnswer {
  id         String   @id @default(cuid())
  attemptId  String
  attempt    Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Restrict)
  selectedOptionIds String[] @default([])
  isCorrect  Boolean  @default(false)
  createdAt  DateTime @default(now())
  @@index([attemptId])
  @@index([questionId])
}
// FLASHCARDS (Deck → Cards)
model FlashcardDeck {
  id          String @id @default(cuid())
  title       String
  description String?
  categoryId  String?
  subjectId   String?
  topicId     String?
  subtopicId  String?
  isPublished Boolean @default(false)
  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cards       FlashcardCard[]
}
model FlashcardCard {
  id          String @id @default(cuid())
  deckId      String
  deck        FlashcardDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  subtopicId  String?
  subtopic    Subtopic? @relation(fields: [subtopicId], references: [id], onDelete: SetNull)
  front       String
  back        String
  imageUrl    String?
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([deckId, order])
}
// CONTENT LIBRARY
// Layer 1: HTML learning pages (non-downloadable, light XP)
// Layer 2: PDF library (downloadable, requires entitlement, no XP)
model ContentPage {
  id          String @id @default(cuid())
  title       String
  categoryId  String?
  subjectId   String?
  topicId     String?
  subtopicId  String?
  subtopic    Subtopic? @relation(fields: [subtopicId], references: [id], onDelete: SetNull)
  body        String
  isPublished Boolean @default(false)
  publishedAt DateTime?
  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([isPublished])
  @@index([subtopicId])
  @@index([categoryId])
}
model PdfAsset {
  id             String @id @default(cuid())
  title          String
  fileUrl        String
  fileSize       Int?
  mimeType       String? @default("application/pdf")
  categoryId     String?
  subjectId      String?
  topicId        String?
  subtopicId     String?
  isDownloadable Boolean @default(true)
  isPublished    Boolean @default(false)
  publishedAt    DateTime?
  createdById    String
  createdBy      User   @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@index([isPublished])
  @@index([categoryId])
}
// PRODUCT BUILDER (packages → entitlements)
model ProductPackage {
  id          String @id @default(cuid())
  code        String @unique
  name        String
  description String?
  entitlementCodes String[] @default([])
  pricePaise  Int    @default(0)
  currency    String @default("INR")
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  purchases   Purchase[]
}
// COUPONS
model Coupon {
  id           String @id @default(cuid())
  code         String @unique
  discountType CouponDiscountType
  discountValue Int
  validFrom    DateTime?
  validUntil   DateTime?
  usageLimit   Int?
  perUserLimit Int?
  applicableEntitlements String[] @default([])
  isActive     Boolean @default(true)
  createdById  String
  createdBy    User   @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  purchases    Purchase[]
}
// XP RULE ENGINE + LEDGER
model XpRule {
  id          String   @id @default(cuid())
  key         XpRuleKey @unique
  value       Int
  isEnabled   Boolean  @default(true)
  dailyCap    Int?
  multiplier  Float    @default(1)
  updatedById String?
  updatedBy   User?    @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}
model XpEvent {
  id          String @id @default(cuid())
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  ruleKey     XpRuleKey
  points      Int
  meta        Json?
  createdAt   DateTime @default(now())
  @@index([userId, createdAt])
  @@index([ruleKey, createdAt])
}
model XpLedgerEntry {
  id          String @id @default(cuid())
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  delta       Int
  reason      String
  refType     String?
  refId       String?
  meta        Json?
  createdAt   DateTime @default(now())
  @@index([userId, createdAt])
}
// REVENUE + ANALYTICS (minimal storage; charts computed)
model Purchase {
  id           String @id @default(cuid())
  userId       String
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  packageId    String?
  package      ProductPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)
  couponId     String?
  coupon       Coupon? @relation(fields: [couponId], references: [id], onDelete: SetNull)
  stream       RevenueStream
  currency     String @default("INR")
  grossPaise   Int
  feePaise     Int    @default(0)
  netPaise     Int
  createdAt    DateTime @default(now())
  @@index([stream, createdAt])
  @@index([userId, createdAt])
}
// AUDIT LOGGING (LOCKED requirement)
model AuditLog {
  id          String   @id @default(cuid())
  actorId     String?
  actor       User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action      String
  entityType  String
  entityId    String?
  before      Json?
  after       Json?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())
  @@index([actorId, createdAt])
  @@index([entityType, entityId])
}

// VIDEO MODULE
enum CourseType {
  STANDARD
  PACKAGE
}

model Course {
  id             String     @id @default(cuid())
  tenantId       String     @default("default")
  name           String
  description    String?
  categoryId     String?
  courseType     CourseType @default(STANDARD)
  isActive       Boolean    @default(true)
  hasHtmlCourse     Boolean    @default(false)
  hasVideoCourse    Boolean    @default(false)
  hasPdfCourse      Boolean    @default(false)
  hasTestSeries     Boolean    @default(false)
  hasFlashcardDecks Boolean    @default(false)
  thumbnailUrl      String?
  createdAt         DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  videos         Video[]
  liveClasses    LiveClass[]
  @@index([categoryId])
  @@index([tenantId])
  @@index([courseType])
}

model Faculty {
  id        String    @id @default(cuid())
  tenantId  String    @default("default")
  name      String
  title     String?
  bio       String?
  avatarUrl String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  videos    Video[]
  liveClasses LiveClass[]
  @@index([tenantId])
}

model Video {
  id               String          @id @default(cuid())
  tenantId         String          @default("default")
  title            String
  description      String?
  facultyId        String?
  faculty          Faculty?        @relation(fields: [facultyId], references: [id], onDelete: SetNull)
  courseId         String?
  course           Course?         @relation(fields: [courseId], references: [id], onDelete: SetNull)
  categoryId       String?
  subjectId        String?
  topicId          String?
  subtopicId       String?
  accessType       VideoAccessType @default(FREE)
  status           VideoStatus     @default(DRAFT)
  lessonOrder      Int?            @default(0)
  durationSeconds  Int?
  thumbnailUrl     String?
  provider         VideoProvider   @default(MANUAL)
  providerVideoId  String?
  hlsUrl           String?
  playbackUrl      String?
  processingStatus String?
  processingError  String?
  allowPreview     Boolean         @default(false)
  tags             String[]        @default([])
  publishedAt      DateTime?
  createdById      String
  createdBy        User            @relation("VideoCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  @@index([status])
  @@index([courseId])
  @@index([categoryId])
  @@index([tenantId])
}

// LIVE CLASSES MODULE
model LiveClass {
  id              String          @id @default(cuid())
  tenantId        String          @default("default")
  title           String
  description     String?
  facultyId       String?
  faculty         Faculty?        @relation(fields: [facultyId], references: [id], onDelete: SetNull)
  courseId        String?
  course          Course?         @relation(fields: [courseId], references: [id], onDelete: SetNull)
  categoryId      String?
  subjectId       String?
  topicId         String?
  subtopicId      String?
  sessionDate     DateTime?
  startTime       String?
  endTime         String?
  accessType      VideoAccessType @default(FREE)
  status          LiveClassStatus @default(DRAFT)
  platform        LivePlatform    @default(ZOOM)
  joinUrl         String?
  sessionCode     String?
  thumbnailUrl    String?
  notifyLearners  Boolean         @default(false)
  recordingPolicy RecordingPolicy @default(NO_RECORD)
  replayVideoId   String?
  publishedAt     DateTime?
  createdById     String
  createdBy       User            @relation("LiveClassCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  @@index([status])
  @@index([sessionDate])
  @@index([courseId])
  @@index([tenantId])
}

// COURSE CONTENT BUILDER
// Structured folder tree + content mappings for a specific course.
// Folders are neutral containers; items are mappings only (never delete source content).

enum CourseItemType {
  VIDEO
  LIVE_CLASS
  PDF
  FLASHCARD_DECK
}

model CourseFolder {
  id          String   @id @default(cuid())
  tenantId    String   @default("default")
  courseId    String
  parentId    String?
  title       String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([courseId])
  @@index([parentId])
  @@index([courseId, parentId, sortOrder])
}

model CourseContentItem {
  id            String         @id @default(cuid())
  tenantId      String         @default("default")
  courseId      String
  folderId      String?
  itemType      CourseItemType
  sourceId      String
  titleSnapshot String?
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([courseId, itemType, sourceId])
  @@index([courseId])
  @@index([folderId])
  @@index([courseId, folderId, sortOrder])
}

// COURSE PACKAGE ITEMS
// Maps existing STANDARD courses into a PACKAGE course by reference.
// No content duplication — child course remains the source of truth.
model CoursePackageItem {
  id              String   @id @default(cuid())
  tenantId        String   @default("default")
  packageCourseId String
  childCourseId   String
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([packageCourseId, childCourseId])
  @@index([packageCourseId, sortOrder])
  @@index([childCourseId])
}

// CONTENT FLOW
// Unified ordered sequence of mixed content (Video, PDF, Flashcard) for a given context.
// Context is defined by any combination of courseId/categoryId/subjectId/topicId/subtopicId.
// Removing a flow item never deletes the underlying source content.
model ContentFlowItem {
  id            String          @id @default(cuid())
  tenantId      String          @default("default")
  courseId      String?
  categoryId    String?
  subjectId     String?
  topicId       String?
  subtopicId    String?
  contentType   FlowContentType
  contentId     String
  titleSnapshot String?
  displayOrder  Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  @@index([tenantId, courseId])
  @@index([tenantId, categoryId, subjectId, topicId, subtopicId])
}

// USER DEVICE TRACKING
enum DeviceType {
  DESKTOP
  MOBILE
  TABLET
  UNKNOWN
}

model UserDevice {
  id            String     @id @default(cuid())
  tenantId      String     @default("default")
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceKey     String
  deviceType    DeviceType @default(UNKNOWN)
  browser       String?
  os            String?
  userAgent     String?
  ipAddressLast String?
  label         String?
  firstSeenAt   DateTime   @default(now())
  lastSeenAt    DateTime   @default(now())
  isActive      Boolean    @default(true)
  isBlocked     Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  @@unique([userId, deviceKey])
  @@index([userId])
  @@index([deviceKey])
  @@index([isActive])
  @@index([lastSeenAt])
}

// USER ACTIVITY LOG
enum ActivityType {
  LOGIN_SUCCESS
  LOGIN_BLOCKED_DEVICE_LIMIT
  LOGIN_BLOCKED_USER
  LOGOUT
  DEVICE_REGISTERED
  DEVICE_REMOVED
  DEVICE_RESET
  GLOBAL_DEVICE_RESET
  USER_BLOCKED
  USER_UNBLOCKED
  USER_EDITED
  USER_SOFT_DELETED
  USER_RESTORED
  SESSION_REVOKED
}

model UserActivity {
  id           String       @id @default(cuid())
  tenantId     String       @default("default")
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  activityType ActivityType
  meta         String?
  deviceKey    String?
  ipAddress    String?
  createdAt    DateTime     @default(now())
  @@index([userId])
  @@index([userId, activityType])
  @@index([createdAt])
}
